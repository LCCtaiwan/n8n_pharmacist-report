    {
      "parameters": {
        "jsCode": "// ── Unified RSS/Atom XML Parser ──────────────────────────────────\nfunction parseXML(xmlText) {\n  const items = [];\n  if (!xmlText || typeof xmlText !== 'string') return items;\n  const isAtom = /<feed[\\s>]/i.test(xmlText);\n  const itemTag = isAtom ? 'entry' : 'item';\n  let feedUrl = '';\n  const chanLink = /<channel[^>]*>[\\s\\S]*?<link[^>]*>([^<]+)<\\/link>/i.exec(xmlText);\n  const atomLink = /<link[^>]*rel=[\"']alternate[\"'][^>]*href=[\"']([^\"']+)[\"']/i.exec(xmlText)\n               || /<link[^>]*href=[\"']([^\"']+)[\"'][^>]*rel=[\"']alternate[\"']/i.exec(xmlText);\n  if (chanLink) feedUrl = chanLink[1].trim();\n  else if (atomLink) feedUrl = atomLink[1].trim();\n  const itemRegex = new RegExp('<' + itemTag + '[^>]*>(.*?)</' + itemTag + '>', 'gis');\n  let m;\n  while ((m = itemRegex.exec(xmlText)) !== null) {\n    const block = m[1];\n    const getTag = (tag) => {\n      const r = new RegExp('<' + tag + '[^>]*><!\\\\[CDATA\\\\[(.*?)\\\\]\\\\]></' + tag + '>|<' + tag + '[^>]*>(.*?)</' + tag + '>', 'is');\n      const x = r.exec(block);\n      return x ? (x[1] || x[2] || '').trim() : '';\n    };\n    const hrefMatch = /<link[^>]*href=[\"']([^\"']+)[\"']/i.exec(block);\n    const link = (hrefMatch ? hrefMatch[1] : '') || getTag('link') || getTag('guid') || getTag('id') || '';\n    const title = getTag('title').replace(/&amp;/g,'&').replace(/&lt;/g,'<').replace(/&gt;/g,'>').replace(/&quot;/g,'\"');\n    const rawDesc = getTag('description') || getTag('summary') || getTag('content') || '';\n    const summary = rawDesc.replace(/<[^>]+>/g, '').replace(/&amp;/g,'&').replace(/&nbsp;/g,' ').substring(0, 350);\n    const pubDate = getTag('pubDate') || getTag('published') || getTag('updated') || getTag('dc:date') || '';\n    if (title) items.push({ title, link, contentSnippet: summary, pubDate, feedUrl });\n  }\n  items.sort((a, b) => {\n    const ta = a.pubDate ? new Date(a.pubDate).getTime() : 0;\n    const tb = b.pubDate ? new Date(b.pubDate).getTime() : 0;\n    return tb - ta;\n  });\n  const cutoff = Date.now() - 10 * 24 * 60 * 60 * 1000;\n  return items.filter(i => {\n    if (!i.pubDate) return true;\n    const t = new Date(i.pubDate).getTime();\n    return isNaN(t) || t >= cutoff;\n  });\n}\n\nconst allItems = [];\nfor (const item of $input.all()) {\n  const xmlText = item.json.data || item.json.body || item.json.response || '';\n  if (!xmlText || typeof xmlText !== 'string' || xmlText.length < 100) continue;\n  const parsed = parseXML(xmlText);\n  allItems.push(...parsed);\n}\n\nreturn allItems.map(i => ({ json: i }));"
      },
