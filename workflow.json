    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst isFDA = (a) => (a.feedUrl || a.link || '').toLowerCase().includes('fda.gov');\n\nconst getSource = (a) => {\n  let key = a.feedUrl || '';\n  if (!key) {\n    try { key = new URL(a.link).hostname; }\n    catch (_) { key = (a.link || '').replace(/^https?:\\/\\//, '').split('/')[0] || 'unknown'; }\n  }\n  return key;\n};\n\nconst SOURCE_LABELS = {\n  'nejm.org':       'NEJM',\n  'thelancet.com':  'The Lancet',\n  'jamanetwork.com':'JAMA',\n  'wiley.com':      'Pharmacotherapy / CP&T',\n  'ascpt':          'CP&T',\n};\n\nconst getLabel = (feedUrl) => {\n  for (const [key, label] of Object.entries(SOURCE_LABELS)) {\n    if ((feedUrl||'').includes(key)) return label;\n  }\n  return feedUrl || 'Unknown';\n};\n\nconst FDA_ITEM_LIMIT = 6;\n\nconst allJournals = items.filter(i => !isFDA(i.json)).map(i => i.json);\nconst allFDA      = items.filter(i =>  isFDA(i.json)).map(i => i.json);\n\nconst bySource = {};\nfor (const a of allJournals) {\n  const key = getSource(a);\n  if (!bySource[key]) bySource[key] = [];\n  bySource[key].push(a);\n}\nfor (const key of Object.keys(bySource)) {\n  bySource[key].sort((a, b) =>\n    new Date(b.pubDate||0) - new Date(a.pubDate||0)\n  );\n}\n\nconst fmt = (a) =>\n  `- ${a.title}\\n  ${a.contentSnippet || ''}\\n  URL: ${a.link}`;\n\nconst today = new Date().toLocaleDateString('zh-TW', {\n  year: 'numeric', month: '2-digit', day: '2-digit', timeZone: 'Asia/Taipei'\n});\nconst dateStr = today.replace(/\\//g, '-');\n\nconst outputs = [];\n\nfor (const [sourceKey, articles] of Object.entries(bySource)) {\n  const label = getLabel(sourceKey);\n  const docTitle = `醫藥新知週報 ${dateStr} — ${label}`;\n  const prompt = 'placeholder';\n  outputs.push({ json: { prompt, docTitle, today, source: label, articleCount: articles.length } });\n}\n\nreturn outputs;"
      },
